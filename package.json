{
  "name": "crontrol-monorepo",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "pnpm --filter @crontrol/shared build && pnpm --filter @crontrol/web build && pnpm --filter @crontrol/server build && pnpm --filter crontrol build",
    "build:status": "npm --prefix packages/status run build",
    "dev": "pnpm --filter @crontrol/web dev",
    "test": "pnpm --filter @crontrol/server test",
    "test:status": "npm --prefix packages/status test",
    "ct": "ct"
  },
  "devDependencies": {
    "crontrol": "workspace:*",
    "typescript": "^5.9.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
